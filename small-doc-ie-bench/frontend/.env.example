# Public env vars are inlined into the client bundle at BUILD TIME (next build).
# When building the Docker image, pass these as build args (see Dockerfile / README).

# Base URL of the FastAPI backend (DocIE Studio endpoints + /metrics).
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Grafana base URL (embedded via iframe on the Observability tab).
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3000

# Inngest dev/dashboard URL (linked from the Observability tab).
NEXT_PUBLIC_INNGEST_URL=http://localhost:8288
