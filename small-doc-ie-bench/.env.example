# Service
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080
MAX_UPLOAD_MB=25
RAW_DOCUMENT_STORAGE=disabled

# Security / auth
# Fails closed by default: every /v1 route (extraction, schemas, reviews,
# workers, studio, serving) requires a valid X-API-Key header. For local
# single-operator dev, set AUTH_REQUIRED=false to disable it. For any shared or
# networked run, leave it true and populate API_KEYS.
AUTH_REQUIRED=false
# JSON object {"<secret-key>": "<tenant-id>"} or "key1:tenantA,key2:tenantB".
# The matched tenant id becomes the worker/reviewer provenance recorded on tasks.
API_KEYS=
# CORS origins allowed to call the API from a browser (the DocIE Studio UI).
# Comma-separated. UNSET now means localhost-only (http://localhost:3000,
# http://127.0.0.1:3000) — a deliberate hardening from the old "*" default. If
# you serve the Studio UI from another host, set the browser origin(s) here
# explicitly (or "*" to allow any, only safe because auth is header-based).
STUDIO_CORS_ORIGINS=

# Database
DATABASE_URL=postgresql+psycopg://docie:docie@postgres:5432/docie
REVIEW_CLAIM_LEASE_SECONDS=900
REVIEW_CONFIDENCE_THRESHOLD=0.7
REVIEW_EVIDENCE_THRESHOLD=0.8
ANNOTATION_EXPORT_DIR=/app/annotations

# Default extraction
DEFAULT_SCHEMA_NAME=invoice
DEFAULT_MODEL_PROFILE=local_llamacpp
DEFAULT_OCR_BACKEND=pdf_text
OCR_CACHE_ENABLED=true
OCR_CACHE_MAX_MB=2048
OCR_CACHE_DIR=/app/.cache/ocr
RUNS_DIR=/app/runs

# Durable Studio artifact store (shared across api + worker). Must resolve to the
# SAME location on every replica; swap for an S3/MinIO mount for multi-host.
ARTIFACT_STORE_DIR=/app/artifacts
# Retention/GC for the Studio run index (nightly gc_studio_runs_job). Age wins
# first, then a hard cap on run count.
STUDIO_RUN_RETENTION_DAYS=30
STUDIO_RUN_RETENTION_MAX=500

# LLM: OpenAI-compatible endpoint
OPENAI_COMPAT_BASE_URL=http://llm-llamacpp:8000/v1
OPENAI_COMPAT_API_KEY=local-not-used
OPENAI_COMPAT_MODEL=local-model
OPENAI_COMPAT_TIMEOUT_SECONDS=180
# llama-cpp-python / vLLM support the stronger openai_json_schema; some backends
# (notably Ollama) reject a strict json_schema with HTTP 400 "failed to parse
# grammar" -- for those set OPENAI_COMPAT_RESPONSE_FORMAT_STYLE=json_object.
OPENAI_COMPAT_RESPONSE_FORMAT_STYLE=openai_json_schema

# Local llama.cpp server container
MODEL_PATH=/models/model.gguf
LLAMA_CPP_N_CTX=4096
LLAMA_CPP_N_THREADS=12
LLAMA_CPP_N_BATCH=256
LLAMA_CPP_HOST=0.0.0.0
LLAMA_CPP_PORT=8000

# Observability
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
OTEL_SERVICE_NAME=small-doc-ie-bench

# Inngest (DocIE Studio async processing)
# Keys must be hex strings with an EVEN number of chars: `openssl rand -hex 32`.
# Shared by the inngest server, the worker, and the API (event sending).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# 0 = production (self-hosted server, keys required). Set 1 only for the local
# `npx inngest-cli dev` workflow.
INNGEST_DEV=0
# Two Inngest apps, one per role (PR-1 service split): the scaled `worker`
# fleet registers INNGEST_APP_ID (extraction/benchmark/GC) and the
# single-replica `serving` service registers INNGEST_SERVING_APP_ID
# (deploy/seed/delete + reconciler). They MUST stay distinct: an Inngest app's
# function set is re-registered on every worker sync, so two fleets syncing
# disjoint function lists under ONE app id would overwrite each other's
# registration on every reconnect (functions flap between registered and
# archived). Events route by name, not app, so triggers are unaffected.
INNGEST_APP_ID=docie-studio
INNGEST_SERVING_APP_ID=docie-serving
# How the worker/API reach the self-hosted server (internal Docker service
# names + INTERNAL container ports 8288/8289 — NOT the host-published ports).
INNGEST_BASE_URL=http://inngest:8288
INNGEST_CONNECT_GATEWAY_URL=ws://inngest:8289/v0/connect

# Host ports for the Inngest dashboard/gateway (override to avoid clashes).
# Distinct from the server's own INNGEST_PORT, which must stay 8288 internally.
INNGEST_HOST_PORT=8288
INNGEST_CONNECT_HOST_PORT=8289

# Serving/deploy state (shared by api + serving + worker via the serving-state
# volume). The GGUF blob store lives under $DOCIE_SERVING_HOME/models; its
# metadata is cataloged in Postgres (requires DATABASE_URL). `llama-server`
# ships in the serving image. Runtime lifecycle (deploy/seed/delete + the
# background reconciler) runs ONLY on the dedicated single-replica `serving`
# service; `worker` scales freely for extraction/benchmark (docker-compose.yml).
DOCIE_SERVING_HOME=/app/.serving

# Cross-container serving reachability. A deployed runtime BINDS
# DOCIE_SERVING_BIND_HOST (all interfaces inside its container) while the
# DeploymentRecord ADVERTISES the single-replica `serving` service name, which
# ALWAYS resolves to the one node that ran the deploy, so siblings reach it at
# e.g. `serving:8088` over the compose network (no published port).
#
# MIGRATION NOTE (PR-1 service split — upgrade trap): a .env written before
# the split carried DOCIE_SERVING_ADVERTISE_HOST=worker. That variable is now
# IGNORED by the serving compose service, which pins its own advertise name
# (`serving`) in docker-compose.yml precisely so a stale .env cannot make
# deploys advertise the freely-scaled worker service (a round-robin endpoint
# that may resolve to a replica that never ran the deploy). Delete any old
# DOCIE_SERVING_ADVERTISE_HOST line from your .env; if you rename the serving
# service, set DOCIE_SERVING_ADVERTISE_HOST_OVERRIDE to the new name. The
# serving process additionally warns at startup when its advertise host names
# a scaled service, and refuses such deploys once the name resolves to more
# than one address.
#DOCIE_SERVING_ADVERTISE_HOST_OVERRIDE=serving
#
# SECURITY: bind/advertise default to the safe loopback 127.0.0.1 in code, so a
# local `docie up`/`docie serve` never exposes the unauth runtime on the LAN.
# Setting BIND=0.0.0.0 here is a deliberate opt-in for the Docker path ONLY, and
# is safe because the runtime is reachable solely on the private compose network
# (there is no `ports:` mapping for it). Do NOT set BIND=0.0.0.0 outside a
# private container network. Leave everything unset for the local CLI, which
# stays same-host on 127.0.0.1.
DOCIE_SERVING_BIND_HOST=0.0.0.0

# Background reconciler cadence on the `serving` service (seconds between
# observation cycles: liveness/RSS publish + gated repair).
DOCIE_SERVING_RECONCILE_INTERVAL=10

# Hard memory limit for the `serving` container (PR-2 resource tracker). With
# an explicit limit the container's cgroup-v2 numbers become the authoritative
# sizing denominator (published as source=cgroup); without one the cgroup
# reads the "max" sentinel and the tracker falls back to the elastic Docker
# Desktop/WSL2 VM view (source=vm, badged as a soft number in the UI). Size it
# to the RAM you actually grant the GGUF runtimes: roughly the sum over
# co-resident deployments of (weights + KV cache + ~0.5 GB runtime slab).
DOCIE_SERVING_MEM_LIMIT=16g

# Per-deploy port allocation window (PR-B). A deploy that supplies no explicit
# port is auto-assigned the first free port in [START, END] that is neither held
# by a non-removed deployment record nor bound by a live socket, so two concurrent
# store deploys land on distinct ports with no operator input. 8088 stays the
# first pick, so a single deploy is unchanged. Widen the window (or stop a
# deployment) if it exhausts. An explicit --port / port= is always honored
# verbatim (the bind arbitrates conflicts; the real llama-server stderr is then
# surfaced onto the deployment's last_error). Best-effort, not race-free: a probed
# port can be grabbed before the runtime binds, and a worker cannot see a
# concurrent host-native `docie up`, so the bind is the authoritative arbiter and
# a bind-collision exit triggers a bounded reallocation.
DOCIE_SERVING_PORT_RANGE_START=8088
DOCIE_SERVING_PORT_RANGE_END=8188

# Host Ollama models dir (read-only mount) so "seed from Ollama" can hard-link
# existing GGUF blobs into the store without re-downloading. Forward slashes on
# Windows. Leave default if you won't seed from Ollama.
OLLAMA_MODELS_HOST=C:/Users/ougue/.ollama/models
