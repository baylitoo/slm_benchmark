# Service
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080
MAX_UPLOAD_MB=25
RAW_DOCUMENT_STORAGE=disabled

# Database
DATABASE_URL=postgresql+psycopg://docie:docie@postgres:5432/docie
REVIEW_CLAIM_LEASE_SECONDS=900
REVIEW_CONFIDENCE_THRESHOLD=0.7
REVIEW_EVIDENCE_THRESHOLD=0.8
ANNOTATION_EXPORT_DIR=/app/annotations

# Default extraction
DEFAULT_SCHEMA_NAME=invoice
DEFAULT_MODEL_PROFILE=local_llamacpp
DEFAULT_OCR_BACKEND=pdf_text
OCR_CACHE_ENABLED=true
OCR_CACHE_MAX_MB=2048
OCR_CACHE_DIR=/app/.cache/ocr
RUNS_DIR=/app/runs

# LLM: OpenAI-compatible endpoint
OPENAI_COMPAT_BASE_URL=http://llm-llamacpp:8000/v1
OPENAI_COMPAT_API_KEY=local-not-used
OPENAI_COMPAT_MODEL=local-model
OPENAI_COMPAT_TIMEOUT_SECONDS=180
OPENAI_COMPAT_RESPONSE_FORMAT_STYLE=openai_json_schema

# Local llama.cpp server container
MODEL_PATH=/models/model.gguf
LLAMA_CPP_N_CTX=4096
LLAMA_CPP_N_THREADS=12
LLAMA_CPP_N_BATCH=256
LLAMA_CPP_HOST=0.0.0.0
LLAMA_CPP_PORT=8000

# Observability
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
OTEL_SERVICE_NAME=small-doc-ie-bench

# Inngest (DocIE Studio async processing)
# Keys must be hex strings with an EVEN number of chars: `openssl rand -hex 32`.
# Shared by the inngest server, the worker, and the API (event sending).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# 0 = production (self-hosted server, keys required). Set 1 only for the local
# `npx inngest-cli dev` workflow.
INNGEST_DEV=0
INNGEST_APP_ID=docie-studio
# How the worker/API reach the self-hosted server (internal Docker service
# names + INTERNAL container ports 8288/8289 — NOT the host-published ports).
INNGEST_BASE_URL=http://inngest:8288
INNGEST_CONNECT_GATEWAY_URL=ws://inngest:8289/v0/connect

# Host ports for the Inngest dashboard/gateway (override to avoid clashes).
# Distinct from the server's own INNGEST_PORT, which must stay 8288 internally.
INNGEST_HOST_PORT=8288
INNGEST_CONNECT_HOST_PORT=8289

# Serving/deploy state (shared by api + worker via the serving-state volume).
# The GGUF blob store lives under $DOCIE_SERVING_HOME/models; its metadata is
# cataloged in Postgres (requires DATABASE_URL). `llama-server` ships in the
# worker image. The worker MUST stay scale=1 (runtime binds worker-local
# 127.0.0.1 and Inngest may route to any replica).
DOCIE_SERVING_HOME=/app/.serving

# Host Ollama models dir (read-only mount) so "seed from Ollama" can hard-link
# existing GGUF blobs into the store without re-downloading. Forward slashes on
# Windows. Leave default if you won't seed from Ollama.
OLLAMA_MODELS_HOST=C:/Users/ougue/.ollama/models
