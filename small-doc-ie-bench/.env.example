# Service
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080
MAX_UPLOAD_MB=25
RAW_DOCUMENT_STORAGE=disabled

# Database
DATABASE_URL=postgresql+psycopg://docie:docie@postgres:5432/docie
REVIEW_CLAIM_LEASE_SECONDS=900
REVIEW_CONFIDENCE_THRESHOLD=0.7
REVIEW_EVIDENCE_THRESHOLD=0.8
ANNOTATION_EXPORT_DIR=/app/annotations

# Default extraction
DEFAULT_SCHEMA_NAME=invoice
DEFAULT_MODEL_PROFILE=local_llamacpp
DEFAULT_OCR_BACKEND=pdf_text
OCR_CACHE_ENABLED=true
OCR_CACHE_MAX_MB=2048
OCR_CACHE_DIR=/app/.cache/ocr
RUNS_DIR=/app/runs

# LLM: OpenAI-compatible endpoint
OPENAI_COMPAT_BASE_URL=http://llm-llamacpp:8000/v1
OPENAI_COMPAT_API_KEY=local-not-used
OPENAI_COMPAT_MODEL=local-model
OPENAI_COMPAT_TIMEOUT_SECONDS=180
OPENAI_COMPAT_RESPONSE_FORMAT_STYLE=openai_json_schema

# Local llama.cpp server container
MODEL_PATH=/models/model.gguf
LLAMA_CPP_N_CTX=4096
LLAMA_CPP_N_THREADS=12
LLAMA_CPP_N_BATCH=256
LLAMA_CPP_HOST=0.0.0.0
LLAMA_CPP_PORT=8000

# Observability
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
OTEL_SERVICE_NAME=small-doc-ie-bench
